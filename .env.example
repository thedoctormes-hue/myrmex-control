# Myrmex Control Environment Variables
# Copy to .env and fill in the values

# JWT secret for token signing (required, min 32 chars)
JWT_SECRET=your-super-secret-jwt-key-change-me

# CORS origin (comma-separated for multiple)
CORS_ORIGIN=http://localhost:5173

# Node environment
NODE_ENV=development

# Port for server
PORT=3000

# Admin password (for initial setup)
MYRMEX_PASSWORD=

# Telegram Bot Token (for TWA auth)
TELEGRAM_BOT_TOKEN=
