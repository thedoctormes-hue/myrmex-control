  "library": [
    {
      "id": "lib-001",
      "name": "Docker Healthcheck",
      "type": "skill",
      "description": "Healthcheck script for Docker containers",
      "content": "#!/bin/sh\n# Docker container healthcheck\nset -e\n\n# Check if process is running\nif ! pgrep -x \"node\" > /dev/null; then\n  echo \"Process not running\"\n  exit 1\nfi\n\n# Check HTTP endpoint\nif ! curl -sf http://localhost:${PORT}/api/health > /dev/null; then\n  echo \"Health endpoint not responding\"\n  exit 1\nfi\n\necho \"✅ Container healthy\"\nexit 0",
      "tags": [
        "docker",
        "healthcheck",
        "devops",
        "monitoring"
      ],
      "source": "demo",
      "created_at": "2026-05-04T11:00:00.000Z"
    },
    {
      "id": "lib-002",
      "name": "JWT Auth Middleware",
      "type": "skill",
      "description": "Express middleware for JWT verification with refresh rotation",
      "content": "import jwt from 'jsonwebtoken';\n\nexport function requireAuth(req, res, next) {\n  const authHeader = req.headers.authorization;\n  if (!authHeader?.startsWith('Bearer ')) {\n    return res.status(401).json({ error: 'Missing token' });\n  }\n  try {\n    const payload = jwt.verify(authHeader.slice(7), process.env.JWT_SECRET);\n    req.auth = payload;\n    next();\n  } catch {\n    res.status(401).json({ error: 'Invalid token' });\n  }\n}",
      "tags": [
        "jwt",
        "auth",
        "middleware",
        "express",
        "security"
      ],
      "source": "demo",
      "created_at": "2026-05-05T16:00:00.000Z"
    },
    {
      "id": "lib-003",
      "name": "Git Commit Hook",
      "type": "hook",
      "description": "Pre-commit hook for conventional commits",
      "content": "#!/bin/bash\n# Conventional commit validator\ncommit_msg=$(cat $1)\npattern=\"^(feat|fix|docs|style|refactor|test|chore|ci|build)(\\(.+\\))?: .{1,72}\"\nif ! [[ $commit_msg =~ $pattern ]]; then\n  echo \"❌ Commit message must follow conventional commits\"\n  exit 1\nfi\necho \"✅ Commit message valid\"",
      "tags": [
        "git",
        "hook",
        "pre-commit",
        "conventional-commits"
      ],
      "source": "demo",
      "created_at": "2026-05-02T14:00:00.000Z"
    },
